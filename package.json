{
  "name": "actionstream",
  "version": "0.1.0",
  "private": true,
  "description": "GitHub Actions DVR Dashboard — time-travel through your CI/CD",
  "scripts": {
    "dev": "next dev --turbopack -p 3000",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "worker": "tsx lib/queue/worker.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx lib/db/seed.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "next": "^15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "@octokit/webhooks": "^13.4.2",
    "@octokit/auth-app": "^7.1.4",
    "@octokit/rest": "^21.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.4.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
